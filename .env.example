# 豆包语音 (Doubao Speech) API 凭证
# 此文件应放在 ~/.b2a/.env（用户主目录下），而非项目源码目录内
# Windows: C:\Users\<你的用户名>\.b2a\.env
# macOS/Linux: ~/.b2a/.env
#
# ENV 环境标识: test = 测试环境, production = 生产环境
VOLC_ENV=test

# 测试环境 API Key（开发调试用）
VOLC_TEST_API_KEY=your_test_api_key_here

# 生产环境 API Key（正式发布用，请勿泄露）
VOLC_PROD_API_KEY=your_prod_api_key_here
