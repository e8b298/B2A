# 火山引擎 (Volcengine) API 凭证
# ENV 环境标识: test = 测试环境, production = 生产环境
VOLC_ENV=test

# 测试环境 API Key（开发调试用，可能有调用频率限制）
VOLC_TEST_ACCESS_KEY=your_test_access_key_here
VOLC_TEST_SECRET_KEY=your_test_secret_key_here

# 生产环境 API Key（正式发布用，请勿泄露）
VOLC_PROD_ACCESS_KEY=your_prod_access_key_here
VOLC_PROD_SECRET_KEY=your_prod_secret_key_here
